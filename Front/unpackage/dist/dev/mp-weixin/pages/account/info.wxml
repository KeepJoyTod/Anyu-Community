<view class="account-page data-v-d1d5276e"><view data-event-opts="{{[['tap',[['chooseAvatar',['$event']]]]]}}" class="avatar-box data-v-d1d5276e" bindtap="__e"><image class="avatar data-v-d1d5276e" src="{{avatarUrl}}" mode="aspectFill"></image><text class="change-tip data-v-d1d5276e">点击更换头像</text></view><view class="table-box data-v-d1d5276e"><view class="table-row data-v-d1d5276e"><view class="table-label data-v-d1d5276e">用户姓名</view><input class="table-input data-v-d1d5276e" placeholder="请输入姓名" data-event-opts="{{[['input',[['__set_model',['$0','userName','$event',[]],['editForm']]]]]}}" value="{{editForm.userName}}" bindinput="__e"/></view><view class="table-row data-v-d1d5276e"><view class="table-label data-v-d1d5276e">用户ID</view><input class="table-input data-v-d1d5276e" placeholder="请输入ID" data-event-opts="{{[['input',[['__set_model',['$0','userId','$event',[]],['editForm']]]]]}}" value="{{editForm.userId}}" bindinput="__e"/></view><view class="table-row data-v-d1d5276e"><view class="table-label data-v-d1d5276e">手机号码</view><input class="table-input data-v-d1d5276e" placeholder="请输入手机号" data-event-opts="{{[['input',[['__set_model',['$0','phonenumber','$event',[]],['editForm']]]]]}}" value="{{editForm.phonenumber}}" bindinput="__e"/></view><view class="table-row data-v-d1d5276e"><view class="table-label data-v-d1d5276e">登录密码</view><input class="table-input data-v-d1d5276e" type="password" placeholder="不修改请留空" data-event-opts="{{[['input',[['__set_model',['$0','password','$event',[]],['editForm']]]]]}}" value="{{editForm.password}}" bindinput="__e"/></view></view><view class="submit-box data-v-d1d5276e"><button data-event-opts="{{[['tap',[['submitUpdate']]]]}}" class="submit-btn data-v-d1d5276e" bindtap="__e">确认修改</button></view></view>