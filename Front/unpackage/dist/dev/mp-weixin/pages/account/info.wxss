
.account-page.data-v-d1d5276e {
	background-color: #f5f7fa;
	min-height: 100vh;
	padding: 30rpx;
}
.avatar-box.data-v-d1d5276e {
	display: flex;
	flex-direction: column;
	align-items: center;
	margin-bottom: 40rpx;
}
.avatar.data-v-d1d5276e {
	width: 160rpx;
	height: 160rpx;
	border-radius: 50%;
	background-color: #eee;
	object-fit: cover;
	border: 4rpx solid #fff;
	box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}
.change-tip.data-v-d1d5276e {
	margin-top: 16rpx;
	font-size: 26rpx;
	color: #666;
}
.table-box.data-v-d1d5276e {
	background: #fff;
	border-radius: 16rpx;
	border: 1rpx solid #eee;
	overflow: hidden;
}
.table-row.data-v-d1d5276e {
	display: flex;
	padding: 28rpx 30rpx;
	border-bottom: 1rpx solid #f0f0f0;
	align-items: center;
}
.table-row.data-v-d1d5276e:last-child {
	border-bottom: none;
}
.table-label.data-v-d1d5276e {
	width: 200rpx;
	font-size: 28rpx;
	color: #666;
}

/* 输入框样式 */
.table-input.data-v-d1d5276e {
	flex: 1;
	font-size: 28rpx;
	color: #333;
	text-align: right;
	padding: 10rpx;
}

/* 提交按钮 */
.submit-box.data-v-d1d5276e {
	margin-top: 40rpx;
	padding: 0 20rpx;
}
.submit-btn.data-v-d1d5276e {
	width: 100%;
	background-color: #007aff;
	color: #fff;
	border-radius: 50rpx;
	padding: 24rpx 0;
	font-size: 32rpx;
	border: none;
}

