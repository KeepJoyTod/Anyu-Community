<view class="sign-up-page data-v-66b8d85e"><view class="bg-wrapper data-v-66b8d85e"><image class="bg-img data-v-66b8d85e" src="/static/bg-samurai.png" mode="aspectFill"></image></view><view class="form-card data-v-66b8d85e"><text class="title data-v-66b8d85e">Java 课程报名</text><view class="form-item data-v-66b8d85e"><text class="label data-v-66b8d85e">姓名</text><input class="input data-v-66b8d85e" placeholder="请输入你的姓名" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['form']]]]]}}" value="{{form.name}}" bindinput="__e"/></view><view class="form-item data-v-66b8d85e"><text class="label data-v-66b8d85e">手机号</text><input class="input data-v-66b8d85e" placeholder="请输入你的手机号" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['form']]]]]}}" value="{{form.phone}}" bindinput="__e"/></view><view class="form-item data-v-66b8d85e"><text class="label data-v-66b8d85e">意向班级</text><picker range="{{classList}}" value="{{form.classIndex}}" data-event-opts="{{[['change',[['onClassChange',['$event']]]]]}}" bindchange="__e" class="data-v-66b8d85e"><view class="picker data-v-66b8d85e">{{classList[form.classIndex]||'请选择'}}</view></picker></view><button data-event-opts="{{[['tap',[['submitForm',['$event']]]]]}}" class="submit-btn data-v-66b8d85e" bindtap="__e">提交报名</button></view></view>