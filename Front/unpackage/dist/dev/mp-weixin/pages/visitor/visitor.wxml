 class="data-v-0c8c5c38"><view class="picker data-v-0c8c5c38">{{selectedDateTime}}</view></picker></view><view data-event-opts="{{[['tap',[['submitForm',['$event']]]]]}}" class="submit-btn data-v-0c8c5c38" bindtap="__e"><text class="data-v-0c8c5c38">提交邀请</text></view></view></view></view></block></view>