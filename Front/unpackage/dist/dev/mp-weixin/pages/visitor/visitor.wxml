<view class="visitor-page data-v-0c8c5c38"><view class="header data-v-0c8c5c38"><text class="title data-v-0c8c5c38">访客邀请</text><text class="subtitle data-v-0c8c5c38">邀请访客，便捷通行</text></view><view class="action-bar data-v-0c8c5c38"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="add-btn data-v-0c8c5c38" bindtap="__e"><text class="btn-icon data-v-0c8c5c38">+</text><text class="btn-text data-v-0c8c5c38">新增邀请</text></view></view><view class="visitor-list data-v-0c8c5c38"><view class="list-header data-v-0c8c5c38"><text class="list-title data-v-0c8c5c38">邀请记录</text></view><block wx:if="{{$root.g0===0}}"><view class="empty-tip data-v-0c8c5c38"><text class="data-v-0c8c5c38">暂无访客邀请记录</text></view></block><block wx:else><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="visitor-item data-v-0c8c5c38"><view class="item-header data-v-0c8c5c38"><text class="visitor-name data-v-0c8c5c38">{{item.$orig.visitorName}}</text><text class="{{['status','data-v-0c8c5c38',(item.$orig.status==='0')?'pending':'',(item.$orig.status==='1')?'visited':'',(item.$orig.status==='2')?'left':'',(item.$orig.status==='3')?'cancelled':'']}}">{{item.m0}}</text></view><view class="item-info data-v-0c8c5c38"><text class="info-row data-v-0c8c5c38">{{"电话："+(item.$orig.visitorPhone||'未填写')}}</text><text class="info-row data-v-0c8c5c38">{{"事由："+(item.$orig.visitReason||'未填写')}}</text><text class="info-row data-v-0c8c5c38">{{"预计来访："+item.m1}}</text><block wx:if="{{item.$orig.inviteCode}}"><text class="info-row data-v-0c8c5c38">{{"邀请码："+item.$orig.inviteCode}}</text></block></view><view class="item-actions data-v-0c8c5c38"><block wx:if="{{item.$orig.status==='0'}}"><view data-event-opts="{{[['tap',[['deleteVisitor',['$0'],[[['visitorList','id',item.$orig.id,'id']]]]]]]}}" class="action-btn delete data-v-0c8c5c38" bindtap="__e"><text class="data-v-0c8c5c38">删除</text></view></block></view></view></block></block></view><block wx:if="{{showAddForm}}"><view da