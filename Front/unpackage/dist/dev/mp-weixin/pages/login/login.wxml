<view class="login-page data-v-b237504c"><view class="login-header data-v-b237504c"><text class="title data-v-b237504c">社区服务</text><text class="subtitle data-v-b237504c">智慧社区，便捷生活</text></view><view class="login-form data-v-b237504c"><view class="form-item data-v-b237504c"><text class="icon data-v-b237504c">👤</text><input class="input data-v-b237504c" placeholder="请输入用户账号" type="text" data-event-opts="{{[['input',[['__set_model',['$0','username','$event',[]],['form']]]]]}}" value="{{form.username}}" bindinput="__e"/></view><view class="form-item data-v-b237504c"><text class="icon data-v-b237504c">🔒</text><input class="input data-v-b237504c" placeholder="请输入密码" type="password" data-event-opts="{{[['input',[['__set_model',['$0','password','$event',[]],['form']]]]]}}" value="{{form.password}}" bindinput="__e"/></view><view class="form-item captcha-item data-v-b237504c"><text class="icon data-v-b237504c">🔤</text><input class="input captcha-input data-v-b237504c" placeholder="请输入验证码" type="text" maxlength="4" data-event-opts="{{[['input',[['__set_model',['$0','code','$event',[]],['form']]]]]}}" value="{{form.code}}" bindinput="__e"/><view data-event-opts="{{[['tap',[['refreshCaptcha',['$event']]]]]}}" class="captcha-box data-v-b237504c" bindtap="__e"><block wx:if="{{captchaImg}}"><image class="captcha-image data-v-b237504c" src="{{captchaImg}}" mode="aspectFill"></image></block><block wx:else><view class="captcha-placeholder data-v-b237504c"><text class="data-v-b237504c">点击刷新</text></view></block></view></view><view data-event-opts="{{[['tap',[['handleLogin',['$event']]]]]}}" class="login-btn data-v-b237504c" bindtap="__e"><text class="data-v-b237504c">登 录</text></view><view data-event-opts="{{[['tap',[['goRegister',['$event']]]]]}}" class="register-link data-v-b237504c" bindtap="__e"><text class="data-v-b237504c">还没有账号？立即注册</text></view></view></view>