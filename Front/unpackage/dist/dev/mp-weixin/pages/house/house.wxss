



















































































































































































































/* 以下 CSS 代码保持不变，这里为了展示省略... */
.house-page.data-v-00c349f0 {
  padding: 40rpx 30rpx;
  background: #F7F8FA;
  min-height: 100vh;
}
/* 顶部 */
.house-top.data-v-00c349f0 {
  background: #fff;
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}
.house-info.data-v-00c349f0 {
  text-align: center;
}
.title.data-v-00c349f0 {
  font-size: 38rpx;
  font-weight: bold;
  color: #2D374B;
  margin-bottom: 12rpx;
  display: block;
}
.address.data-v-00c349f0 {
  font-size: 28rpx;
  color: #8E9AAD;
}
/* 开锁 */
.lock-card.data-v-00c349f0 {
  background: linear-gradient(135deg, #4361EE, #7B61FF);
  border-radius: 30rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(67, 97, 238, 0.25);
}
.lock-icon.data-v-00c349f0 {
  font-size: 66rpx;
  margin-right: 30rpx;
}
.lock-title.data-v-00c349f0 {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}
.lock-desc.data-v-00c349f0 {
  font-size: 26rpx;
  opacity: 0.9;
}
/* 网格 */
.control-grid.data-v-00c349f0 {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}
.control-item.data-v-00c349f0 {
  flex: 1;
  min-width: 210rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 50rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
  position: relative;
}
.icon.data-v-00c349f0 {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 24rpx;
  transition: 0.3s;
}
.name.data-v-00c349f0 {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 24rpx;
}
/* 空调面板内信息 */
.air-info.data-v-00c349f0 {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.temp.data-v-00c349f0 {
  font-size: 32rpx;
  font-weight: bold;
  color: #2196F3;
}
.brand.data-v-00c349f0 {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
/* 开关 */
.switch.data-v-00c349f0 {
  width: 74rpx;
  height: 42rpx;
  border-radius: 42rpx;
  background: #E0E6ED;
  position: relative;
  transition: all 0.25s ease;
}
.switch.on.data-v-00c349f0 {
  background: #4361EE;
}
.slider.data-v-00c349f0 {
  width: 38rpx;
  height: 38rpx;
  background: #fff;
  border-radius: 50%;
  position: absolute;
  left: 2rpx;
  top: 2rpx;
  transition: 0.25s;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
}
.switch.on .slider.data-v-00c349f0 {
  left: 34rpx;
}
/* 空调弹窗 */
.modal-mask.data-v-00c349f0 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}
.modal-content.data-v-00c349f0 {
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 40rpx 60rpx;
  width: 100%;
}
.modal-header.data-v-00c349f0 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}
.modal-title.data-v-00c349f0 {
  font-size: 40rpx;
  font-weight: bold;
  color: #2D374B;
}
.close-btn.data-v-00c349f0 {
  font-size: 50rpx;
  color: #999;
  line-height: 1;
}
/* 品牌 */
.label.data-v-00c349f0 {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}
.brand-list.data-v-00c349f0 {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.brand-item.data-v-00c349f0 {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #F5F7F9;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
}
.brand-item.active.data-v-00c349f0 {
  background: #4361EE;
  color: #fff;
}
/* 温度 */
.temp-btns.data-v-00c349f0 {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 50rpx;
}
.temp-btn.data-v-00c349f0 {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #F5F7F9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
}
.temp-show.data-v-00c349f0 {
  font-size: 60rpx;
  font-weight: bold;
  color: #2D374B;
  min-width: 100rpx;
  text-align: center;
}
/* 底部 */
.modal-footer.data-v-00c349f0 {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}
.status.data-v-00c349f0 {
  font-size: 28rpx;
  color: #666;
}

