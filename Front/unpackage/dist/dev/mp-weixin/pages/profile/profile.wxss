
.profile-page.data-v-60cb334c {
	background-color: #F2F5FA;
	min-height: 100vh;
	padding-bottom: 80rpx;
}

/* 顶部头部 */
.profile-header.data-v-60cb334c {
	background: linear-gradient(160deg, #5B9FE8 0%, #1A6FD4 100%);
	padding: 60rpx 30rpx 0;
	border-radius: 0 0 48rpx 48rpx;
	margin-bottom: 24rpx;
}
.header-content.data-v-60cb334c {
	display: flex;
	align-items: center;
	margin-bottom: 36rpx;
}
.avatar-wrap.data-v-60cb334c {
	position: relative;
	margin-right: 24rpx;
}
.avatar.data-v-60cb334c {
	width: 120rpx;
	height: 120rpx;
	border-radius: 50%;
	border: 4rpx solid rgba(255, 255, 255, 0.8);
	display: flex;
	align-items: center;
	justify-content: center;
	box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}
.avatar-text.data-v-60cb334c {
	font-size: 56rpx;
	font-weight: bold;
	color: #fff;
}
.avatar-verified.data-v-60cb334c {
	position: absolute;
	bottom: 0;
	right: 0;
	width: 36rpx;
	height: 36rpx;
	background: #fff;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 20rpx;
	color: #1A6FD4;
	font-weight: bold;
	box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}
.user-info.data-v-60cb334c {
	flex: 1;
}
.name.data-v-60cb334c {
	font-size: 40rpx;
	font-weight: 700;
	color: #fff;
	display: block;
	margin-bottom: 12rpx;
}
.badge.data-v-60cb334c {
	display: flex;
	align-items: center;
	gap: 16rpx;
}
.tag.data-v-60cb334c {
	font-size: 22rpx;
	color: #1A6FD4;
	background: rgba(255, 255, 255, 0.92);
	padding: 4rpx 18rpx;
	border-radius: 30rpx;
}
.id.data-v-60cb334c {
	font-size: 24rpx;
	color: rgba(255, 255, 255, 0.75);
}

/* 数据统计栏 */
.stats-bar.data-v-60cb334c {
	background: rgba(255, 255, 255, 0.2);
	border-radius: 24rpx 24rpx 0 0;
	display: flex;
	padding: 28rpx 0;
}
.stat-item.data-v-60cb334c {
	flex: 1;
	display: flex;
	flex-direction: column;
	align-items: center;
}
.stat-divider.data-v-60cb334c {
	width: 2rpx;
	background: rgba(255, 255, 255, 0.4);
	margin: 8rpx 0;
}
.stat-value.data-v-60cb334c {
	font-size: 36rpx;
	font-weight: bold;
	color: #fff;
	margin-bottom: 6rpx;
}
.stat-label.data-v-60cb334c {
	font-size: 24rpx;
	color: rgba(255, 255, 255, 0.75);
}

/* 菜单列表 */
.menu-list.data-v-60cb334c {
	background-color: #fff;
	border-radius: 24rpx;
	margin: 0 24rpx 24rpx;
	overflow: hidden;
	box-shadow: 0 4rpx 20rpx rgba(26, 111, 212, 0.08);
}
.menu-item.data-v-60cb334c {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 28rpx 30rpx;
	border-bottom: 1rpx solid #f5f5f5;
}
.menu-item.data-v-60cb334c:last-child {
	border-bottom: none;
}
.menu-left.data-v-60cb334c {
	display: flex;
	align-items: center;
	gap: 20rpx;
	flex: 1;
}
.menu-icon-wrap.data-v-60cb334c {
	width: 72rpx;
	height: 72rpx;
	border-radius: 20rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}
.menu-icon.data-v-60cb334c {
	font-size: 36rpx;
}
.menu-name.data-v-60cb334c {
	font-size: 30rpx;
	color: #1c2f4a;
	font-weight: 500;
}
.menu-right-group.data-v-60cb334c {
	display: flex;
	align-items: center;
	gap: 8rpx;
}
.menu-desc.data-v-60cb334c {
	font-size: 26rpx;
	color: #9aafc7;
}
.menu-arrow.data-v-60cb334c {
	font-size: 44rpx;
	color: #c2d0e0;
	font-weight: 300;
	line-height: 1;
}

/* 图片美化 */
.service-icon-img.data-v-60cb334c {
	width: 80rpx;
	height: 80rpx;
	border-radius: 16rpx;
}

/* 服务卡片 */
.service-card.data-v-60cb334c {
	background: linear-gradient(135deg, #5B9FE8 0%, #1A6FD4 100%);
	border-radius: 24rpx;
	padding: 32rpx 30rpx;
	margin: 0 24rpx 24rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	color: #fff;
	position: relative;
	overflow: hidden;
}
.service-deco-circle.data-v-60cb334c {
	position: absolute;
	right: -50rpx;
	top: -50rpx;
	width: 220rpx;
	height: 220rpx;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.1);
	pointer-events: none;
}
.service-left.data-v-60cb334c {
	display: flex;
	align-items: center;
	gap: 20rpx;
	flex: 1;
}
.service-info.data-v-60cb334c {
	flex: 1;
}
.service-name.data-v-60cb334c {
	font-size: 30rpx;
	font-weight: bold;
	margin-bottom: 8rpx;
	display: block;
}
.service-sub.data-v-60cb334c {
	font-size: 24rpx;
	opacity: 0.85;
	display: block;
}
.service-btn.data-v-60cb334c {
	background: #fff;
	color: #1A6FD4;
	padding: 16rpx 32rpx;
	border-radius: 60rpx;
	font-size: 26rpx;
	font-weight: 600;
	white-space: nowrap;
	position: relative;
	z-index: 1;
	flex-shrink: 0;
}

/* 退出登录 */
.logout.data-v-60cb334c {
	margin: 0 24rpx 32rpx;
	text-align: center;
	padding: 20rpx;
	color: #9aafc7;
	font-size: 28rpx;
}

/* 底部 */
.footer.data-v-60cb334c {
	text-align: center;
	padding: 0 0 20rpx;
}
.links.data-v-60cb334c {
	display: flex;
	justify-content: center;
	gap: 30rpx;
	margin-bottom: 16rpx;
}
.links text.data-v-60cb334c {
	font-size: 26rpx;
	color: #9aafc7;
}
.divider.data-v-60cb334c {
	color: #ccd8e8;
}
.version.data-v-60cb334c {
	font-size: 22rpx;
	color: #aabdd4;
	letter-spacing: 2rpx;
}

