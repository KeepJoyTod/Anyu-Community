	-webkit-animation: heart-fall-data-v-2c27ccda 2.5s ease-in-out forwards;
	        animation: heart-fall-data-v-2c27ccda 2.5s ease-in-out forwards;
}
@-webkit-keyframes heart-fall-data-v-2c27ccda {
0% {
		-webkit-transform: translate(-50%, -50%) scale(0);
