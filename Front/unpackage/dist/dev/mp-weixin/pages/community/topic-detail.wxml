<view class="topic-detail data-v-20f21764"><image class="activity-img data-v-20f21764" src="{{activity.imageUrl}}" mode="widthFix" data-event-opts="{{[['tap',[['previewImage',['$event']]]]]}}" bindtap="__e"></image><view class="header data-v-20f21764"><text class="header-title data-v-20f21764">{{activity.title}}</text></view><view class="info-card data-v-20f21764"><view class="info-item data-v-20f21764"><text class="info-label data-v-20f21764">🕒 活动时间</text><text class="info-value data-v-20f21764">{{activity.time}}</text></view><view class="info-item data-v-20f21764"><text class="info-label data-v-20f21764">📍 活动地点</text><text class="info-value data-v-20f21764">{{activity.address}}</text></view><view class="info-item data-v-20f21764"><text class="info-label data-v-20f21764">👥 招募人数</text><text class="info-value data-v-20f21764">{{activity.count+"人"}}</text></view><view class="info-item data-v-20f21764"><text class="info-label data-v-20f21764">📞 联系人员</text><text class="info-value data-v-20f21764">{{activity.contact}}</text></view></view><view class="content-card data-v-20f21764"><text class="content-title data-v-20f21764">📝 活动详情</text><view class="content-text data-v-20f21764">{{activity.content}}</view></view><view class="register-wrap data-v-20f21764"><button data-event-opts="{{[['tap',[['toggleRegister',['$event']]]]]}}" class="{{['register-btn','data-v-20f21764',(hasRegistered)?'active':'']}}" bindtap="__e">{{''+(hasRegistered?'取消报名':'立即报名')+''}}</button></view><block wx:if="{{showPointsToast}}"><view class="points-toast data-v-20f21764"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="points-toast-mask data-v-20f21764" bindtap="__e"></view><view class="points-toast-box data-v-20f21764"><view class="points-toast-top data-v-20f21764"></view><view class="points-icon data-v-20f21764"><text class="icon data-v-20f21764">🎁</text></view><view class="points-number data-v-20f21764"><text class="plus data-v-20f21764">+</text><text class="num data-v-20f21764">{{pointsNum}}</text><text class="unit data-v-20f21764">积分</text></view><view class="points-desc data-v-20f21764"><text class="title data-v-20f21764">报名成功！</text><text class="sub-title data-v-20f21764">积分已发放至您的账户</text></view><button data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="points-close-btn data-v-20f21764" bindtap="__e"> 知道啦 </button></view></view></block><block wx:if="{{showDeductToast}}"><view class="points-toast data-v-20f21764"><view data-event-opts="{{[['tap',[['e2',['$event']]]]]}}" class="points-toast-mask data-v-20f21764" bindtap="__e"></view><view class="points-toast-box deduct-box data-v-20f21764"><view class="points-toast-top deduct-top data-v-20f21764"></view><view class="points-icon data-v-20f21764"><text class="icon data-v-20f21764">💔</text></view><view class="points-number data-v-20f21764"><text class="plus deduct-plus data-v-20f21764">-</text><text class="num deduct-num data-v-20f21764">{{pointsNum}}</text><text class="unit data-v-20f21764">积分</text></view><view class="points-desc data-v-20f21764"><text class="title data-v-20f21764">取消报名！</text><text class="sub-title data-v-20f21764">积分已从您的账户扣除</text></view><button data-event-opts="{{[['tap',[['e3',['$event']]]]]}}" class="points-close-btn deduct-btn data-v-20f21764" bindtap="__e"> 知道啦 </button></view></view></block></view>