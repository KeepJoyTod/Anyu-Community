<view class="bill-page data-v-5c84f166"><view class="header data-v-5c84f166"><text class="title data-v-5c84f166">生活缴费</text><text class="subtitle data-v-5c84f166">便捷缴费，轻松生活</text></view><view class="summary-card data-v-5c84f166"><view class="summary-item data-v-5c84f166"><text class="summary-label data-v-5c84f166">待缴费</text><text class="summary-value data-v-5c84f166">{{unpaidCount+"笔"}}</text></view><view class="summary-item data-v-5c84f166"><text class="summary-label data-v-5c84f166">欠费金额</text><text class="summary-value highlight data-v-5c84f166">{{"¥"+totalArrears}}</text></view></view><view class="bill-list data-v-5c84f166"><view class="list-header data-v-5c84f166"><text class="list-title data-v-5c84f166">账单列表</text></view><block wx:if="{{$root.g0===0}}"><view class="empty-tip data-v-5c84f166"><text class="data-v-5c84f166">暂无账单</text></view></block><block wx:else><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="bill-item data-v-5c84f166"><view class="item-left data-v-5c84f166"><view class="{{['bill-icon','data-v-5c84f166',(item.$orig.billType==='1')?'property':'',(item.$orig.billType==='2')?'water':'',(item.$orig.billType==='3')?'electricity':'',(item.$orig.billType==='4')?'gas':'',(item.$orig.billType==='5')?'parking':'',(item.$orig.billType==='6')?'other':'']}}"><text class="data-v-5c84f166">{{item.m0}}</text></view></view><view class="item-center data-v-5c84f166"><text class="bill-type data-v-5c84f166">{{item.m1}}</text><text class="bill-no data-v-5c84f166">{{"账单号："+(item.$orig.billNo||'-')}}</text><text class="bill-date data-v-5c84f166">{{"账单日期："+item.m2}}</text></view><view class="item-right data-v-5c84f166"><text class="bill-amount data-v-5c84f166">{{"¥"+(item.$orig.arrearsAmount||item.$orig.billAmount)}}</text><text class="{{['bill-status','data-v-5c84f166',(item.$orig.status==='0')?'unpaid':'',(item.$orig.status==='1')?'partial':'',(item.$orig.status==='2')?'paid':'']}}">{{item.m3}}</text></view></view></block></block></view><view class="payment-records data-v-5c84f166"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" class="section-header data-v-5c84f166" bindtap="__e"><text class="section-title data-v-5c84f166">缴费记录</text><text class="toggle data-v-5c84f166">{{showRecords?'收起':'展开'}}</text></view><block wx:if="{{$root.g1}}"><view class="empty-tip data-v-5c84f166"><text class="data-v-5c84f166">暂无缴费记录</text></view></block><block wx:if="{{$root.g2}}"><view class="record-list data-v-5c84f166"><block wx:for="{{$root.l1}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="record-item data-v-5c84f166"><view class="record-info data-v-5c84f166"><text class="record-amount data-v-5c84f166">{{"¥"+item.$orig.payAmount}}</text><text class="record-method data-v-5c84f166">{{item.m4}}</text></view><view class="record-time data-v-5c84f166"><text class="data-v-5c84f166">{{item.m5}}</text></view></view></block></view></block></view></view>