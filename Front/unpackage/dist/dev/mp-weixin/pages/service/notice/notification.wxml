<view class="notification-page data-v-b3733302"><view class="bg-blur data-v-b3733302"></view><view class="nav-bar data-v-b3733302"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-b3733302" bindtap="__e"><text class="back-icon data-v-b3733302">←</text></view><text class="nav-title data-v-b3733302">通知提醒</text><view class="placeholder data-v-b3733302"></view></view><view class="action-bar data-v-b3733302"><text class="mark-all-read data-v-b3733302" disabled="{{loading}}" data-event-opts="{{[['tap',[['markAllRead',['$event']]]]]}}" bindtap="__e">全部已读</text></view><block wx:if="{{loading}}"><view class="loading-state data-v-b3733302"><text class="loading-icon data-v-b3733302">⏳</text><text class="loading-text data-v-b3733302">加载中...</text></view></block><block wx:else><block wx:if="{{$root.g0}}"><scroll-view class="notification-list data-v-b3733302" scroll-y="{{true}}"><block wx:for="{{sortedNotifications}}" wx:for-item="item" wx:for-index="__i0__" wx:key="id"><view data-event-opts="{{[['tap',[['goDetail',['$0'],[[['sortedNotifications','id',item.id,'id']]]]]]]}}" class="{{['notification-card','data-v-b3733302',(!item.read)?'unread':'']}}" bindtap="__e"><view class="card-icon data-v-b3733302">{{item.icon}}</view><view class="card-content data-v-b3733302"><view class="card-header data-v-b3733302"><text class="title data-v-b3733302">{{item.title}}</text><text class="{{['status','data-v-b3733302',(!item.read)?'unread':'']}}">{{item.read?'已读':'未读'}}</text></view><text class="desc data-v-b3733302">{{item.content}}</text><block wx:if="{{item.more_info}}"><text class="extra data-v-b3733302">{{item.more_info}}</text></block><text class="time data-v-b3733302">{{item.time}}</text></view></view></block></scroll-view></block><block wx:else><view class="empty-state data-v-b3733302"><text class="empty-icon data-v-b3733302">📭</text><text class="empty-text data-v-b3733302">暂无通知</text></view></block></block></view>