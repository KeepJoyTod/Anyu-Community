<view class="repair-page data-v-38434d4c"><view class="bg-blur data-v-38434d4c"></view><view class="nav-bar data-v-38434d4c"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-38434d4c" bindtap="__e"><text class="back-icon data-v-38434d4c">←</text></view><text class="nav-title data-v-38434d4c">报事报修</text><view class="placeholder data-v-38434d4c"></view></view><view class="form-card data-v-38434d4c"><view class="type-section data-v-38434d4c"><text class="section-label data-v-38434d4c">维修类型</text><scroll-view class="type-scroll data-v-38434d4c" scroll-x="{{true}}" show-scrollbar="false"><view class="type-list data-v-38434d4c"><block wx:for="{{repairTypes}}" wx:for-item="item" wx:for-index="idx" wx:key="idx"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({item})}}" class="{{['type-item','data-v-38434d4c',(selectedType===item.value)?'active':'']}}" bindtap="__e"><text class="type-icon data-v-38434d4c">{{item.icon}}</text><text class="type-name data-v-38434d4c">{{item.name}}</text></view></block></view></scroll-view></view><view class="form-item data-v-38434d4c"><text class="label data-v-38434d4c">问题描述</text><textarea class="textarea data-v-38434d4c" placeholder="请详细描述故障现象（必填）" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','desc','$event',[]],['form']]]]]}}" value="{{form.desc}}" bindinput="__e"></textarea></view><view class="form-item data-v-38434d4c"><text class="label data-v-38434d4c">联系人</text><input class="input data-v-38434d4c" placeholder="请输入姓名" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','contactName','$event',[]],['form']]]]]}}" value="{{form.contactName}}" bindinput="__e"/></view><view class="form-item data-v-38434d4c"><text class="label data-v-38434d4c">联系电话</text><input class="input data-v-38434d4c" type="number" placeholder="请输入手机号" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['form']]]]]}}" value="{{form.phone}}" bindinput="__e"/></view><view class="form-item data-v-38434d4c"><text class="label data-v-38434d4c">预约日期</text><picker mode="date" value="{{form.appointmentDate}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e" class="data-v-38434d4c"><view class="picker data-v-38434d4c">{{form.appointmentDate||'请选择日期'}}</view></picker></view><view class="form-item data-v-38434d4c"><text class="label data-v-38434d4c">预约时间</text><picker mode="time" value="{{form.appointmentClock}}" data-event-opts="{{[['change',[['onClockChange',['$event']]]]]}}" bindchange="__e" class="data-v-38434d4c"><view class="picker data-v-38434d4c">{{form.appointmentClock||'请选择时间'}}</view></picker></view><view class="form-item data-v-38434d4c"><text class="label data-v-38434d4c">详细地址</text><input class="input data-v-38434d4c" placeholder="请输入详细地址" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','address','$event',[]],['form']]]]]}}" value="{{form.address}}" bindinput="__e"/></view><view class="form-item data-v-38434d4c"><text class="label data-v-38434d4c">上传图片</text><view class="image-list data-v-38434d4c"><block wx:for="{{images}}" wx:for-item="img" wx:for-index="idx" wx:key="idx"><view class="image-item data-v-38434d4c"><image class="uploaded-img data-v-38434d4c" src="{{img}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',[idx]]]]]}}" bindtap="__e"></image><view data-event-opts="{{[['tap',[['deleteImage',[idx]]]]]}}" class="delete-btn data-v-38434d4c" bindtap="__e">×</view></view></block><block wx:if="{{$root.g0<3}}"><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="add-image data-v-38434d4c" bindtap="__e"><text class="add-icon data-v-38434d4c">+</text><text class="add-text data-v-38434d4c">上传图片</text></view></block></view><text class="tip-text data-v-38434d4c">最多上传3张图片，支持jpg/png格式</text></view><view data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" class="submit-btn data-v-38434d4c" bindtap="__e"><text class="data-v-38434d4c">提交报修</text></view></view><view class="tips data-v-38434d4c"><text class="tips-text data-v-38434d4c">* 提交后，我们会尽快安排师傅联系您，请保持电话畅通</text></view></view>