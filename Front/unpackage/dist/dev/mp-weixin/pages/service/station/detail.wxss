
.detail-page.data-v-da16c642 {
	position: relative;
	min-height: 100vh;
	background: #f6f9fc;
	padding: 0 32rpx 60rpx;
	overflow-x: hidden;
}
.bg-blur.data-v-da16c642 {
	position: fixed;
	top: -20%;
	right: -20%;
	width: 140%;
	height: 140%;
	background: radial-gradient(circle at 80% 20%, rgba(107, 140, 66, 0.08) 0%, rgba(107, 140, 66, 0.02) 60%, transparent 90%);
	pointer-events: none;
	z-index: 0;
}
.nav-bar.data-v-da16c642 {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 30rpx 0 20rpx;
	position: relative;
	z-index: 2;
}
.back-btn.data-v-da16c642 {
	width: 72rpx;
	height: 72rpx;
	background: rgba(255,255,255,0.8);
	-webkit-backdrop-filter: blur(12rpx);
	        backdrop-filter: blur(12rpx);
	border-radius: 36rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.back-icon.data-v-da16c642 {
	font-size: 48rpx;
	color: #3c5a3e;
	font-weight: 500;
}
.nav-title.data-v-da16c642 {
	font-size: 36rpx;
	font-weight: 600;
	color: #1f3b2c;
	letter-spacing: 1rpx;
}
.placeholder.data-v-da16c642 {
	width: 72rpx;
}

/* 信息卡片 */
.info-card.data-v-da16c642, .track-card.data-v-da16c642 {
	background: rgba(255,255,255,0.92);
	-webkit-backdrop-filter: blur(12rpx);
	        backdrop-filter: blur(12rpx);
	border-radius: 44rpx;
	padding: 32rpx;
	margin-bottom: 32rpx;
	box-shadow: 0 20rpx 40rpx -16rpx rgba(0,0,0,0.08), 0 0 0 1rpx rgba(107,140,66,0.1);
}
.card-header.data-v-da16c642 {
	display: flex;
	justify-content: space-between;
	align-items: baseline;
	margin-bottom: 24rpx;
}
.company.data-v-da16c642 {
	font-size: 36rpx;
	font-weight: 700;
	color: #1f2e3a;
}
.status.data-v-da16c642 {
	font-size: 26rpx;
	padding: 6rpx 20rpx;
	border-radius: 60rpx;
	font-weight: 500;
}
.status.pending.data-v-da16c642 {
	color: #e6892e;
	background: rgba(230,137,46,0.12);
}
.status.in_transit.data-v-da16c642 {
	color: #3b82f6;
	background: rgba(59,130,246,0.12);
}
.status.delivering.data-v-da16c642 {
	color: #8b5cf6;
	background: rgba(139,92,246,0.12);
}
.status.picked.data-v-da16c642 {
	color: #8b9bae;
	background: rgba(0,0,0,0.04);
}
.divider.data-v-da16c642 {
	height: 1rpx;
	background: rgba(107,140,66,0.2);
	margin: 20rpx 0;
}
.info-row.data-v-da16c642 {
	display: flex;
	justify-content: space-between;
	align-items: baseline;
	padding: 16rpx 0;
	border-bottom: 1rpx solid rgba(107,140,66,0.1);
}
.info-row.data-v-da16c642:last-child {
	border-bottom: none;
}
.label.data-v-da16c642 {
	font-size: 28rpx;
	color: #7c8f9e;
}
.value.data-v-da16c642 {
	font-size: 28rpx;
	color: #1c2e3a;
	font-weight: 500;
}
.status-desc.data-v-da16c642 {
	color: #6b8c42;
}

/* 物流轨迹 */
.track-title.data-v-da16c642 {
	font-size: 32rpx;
	font-weight: 700;
	color: #1f2e3a;
	margin-bottom: 24rpx;
}
.track-list.data-v-da16c642 {
	display: flex;
	flex-direction: column;
	gap: 28rpx;
}
.track-item.data-v-da16c642 {
	display: flex;
	gap: 24rpx;
}
.track-dot.data-v-da16c642 {
	width: 16rpx;
	height: 16rpx;
	border-radius: 8rpx;
	background: #d4e0cc;
	margin-top: 8rpx;
	flex-shrink: 0;
}
.track-dot.active.data-v-da16c642 {
	background: #6b8c42;
	width: 20rpx;
	height: 20rpx;
	border-radius: 10rpx;
	box-shadow: 0 0 0 6rpx rgba(107,140,66,0.2);
}
.track-content.data-v-da16c642 {
	flex: 1;
}
.track-time.data-v-da16c642 {
	font-size: 24rpx;
	color: #9aabb8;
	display: block;
	margin-bottom: 8rpx;
}
.track-desc.data-v-da16c642 {
	font-size: 28rpx;
	color: #1f2e3a;
	line-height: 1.4;
}

/* 操作按钮 */
.action-btn.data-v-da16c642 {
	position: relative;
	z-index: 2;
	margin: 40rpx 0 20rpx;
}
.pickup-btn.data-v-da16c642 {
	background: linear-gradient(105deg, #6b8c42, #528a34);
	border-radius: 80rpx;
	padding: 28rpx 0;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 34rpx;
	font-weight: 700;
	color: white;
	box-shadow: 0 12rpx 28rpx rgba(107,140,66,0.3);
	transition: all 0.2s;
}
.pickup-btn.data-v-da16c642:active {
	-webkit-transform: scale(0.98);
	        transform: scale(0.98);
	opacity: 0.9;
}
.tips.data-v-da16c642 {
	text-align: center;
	margin-top: 20rpx;
}
.tips-text.data-v-da16c642 {
	font-size: 24rpx;
	color: #9aabb8;
}

