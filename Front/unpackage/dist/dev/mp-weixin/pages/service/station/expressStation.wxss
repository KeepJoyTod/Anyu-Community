/* 包裹列表 */
.package-list.data-v-651298b2 {
	max-height: calc(100vh - 380rpx);
	position: relative;
	z-index: 2;
}
.package-card.data-v-651298b2 {
	background: rgba(255,255,255,0.92);
	-webkit-backdrop-filter: blur(12rpx);
	        backdrop-filter: blur(12rpx);
	border-radius: 44rpx;
	padding: 28rpx;
	margin-bottom: 24rpx;
	display: flex;
	justify-content: space-between;
	align-items: center;
	box-shadow: 0 20rpx 40rpx -16rpx rgba(0,0,0,0.08), 0 0 0 1rpx rgba(107,140,66,0.1);
	transition: all 0.2s;
}
.package-card.data-v-651298b2:active {
	-webkit-transform: scale(0.98);
	        transform: scale(0.98);
	background: white;
}

/* 已取件样式 */
.package-card.picked.data-v-651298b2 {
	opacity: 0.7;
}
.card-left.data-v-651298b2 {
