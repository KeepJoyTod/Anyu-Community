
.express-page.data-v-651298b2 {
	position: relative;
	min-height: 100vh;
	background: #f6f9fc;
	padding: 0 32rpx 60rpx;
	overflow-x: hidden;
}
.bg-blur.data-v-651298b2 {
	position: fixed;
	top: -20%;
	right: -20%;
	width: 140%;
	height: 140%;
	background: radial-gradient(circle at 80% 20%, rgba(107, 140, 66, 0.08) 0%, rgba(107, 140, 66, 0.02) 60%, transparent 90%);
	pointer-events: none;
	z-index: 0;
}

/* 顶部导航栏 */
.nav-bar.data-v-651298b2 {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 30rpx 0 20rpx;
	position: relative;
	z-index: 2;
}
.back-btn.data-v-651298b2 {
	width: 72rpx;
	height: 72rpx;
	background: rgba(255,255,255,0.8);
	-webkit-backdrop-filter: blur(12rpx);
	        backdrop-filter: blur(12rpx);
	border-radius: 36rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.back-icon.data-v-651298b2 {
	font-size: 48rpx;
	color: #3c5a3e;
	font-weight: 500;
}
.nav-title.data-v-651298b2 {
	font-size: 36rpx;
	font-weight: 600;
	color: #1f3b2c;
	letter-spacing: 1rpx;
}
.placeholder.data-v-651298b2 {
	width: 72rpx;
}

/* 统计卡片 */
.stats-card.data-v-651298b2 {
	background: rgba(255,255,255,0.92);
	-webkit-backdrop-filter: blur(12rpx);
	        backdrop-filter: blur(12rpx);
