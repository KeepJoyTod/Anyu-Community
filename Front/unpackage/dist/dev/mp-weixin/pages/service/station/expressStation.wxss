}
.stats-icon.data-v-651298b2 {
	font-size: 64rpx;
	width: 96rpx;
	height: 96rpx;
	background: rgba(107,140,66,0.12);
	border-radius: 48rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}
.stats-content.data-v-651298b2 {
	flex: 1;
}
.stats-label.data-v-651298b2 {
	font-size: 28rpx;
