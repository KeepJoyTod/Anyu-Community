<view class="invite-page data-v-7f108c9a"><view class="bg-blur data-v-7f108c9a"></view><view class="nav-bar data-v-7f108c9a"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-7f108c9a" bindtap="__e"><text class="back-icon data-v-7f108c9a">←</text></view><text class="nav-title data-v-7f108c9a">访客邀请</text><view class="placeholder data-v-7f108c9a"></view></view><view class="form-card data-v-7f108c9a"><view class="form-title data-v-7f108c9a"><text class="title-icon data-v-7f108c9a">👤</text><text class="data-v-7f108c9a">填写访客信息</text></view><view class="form-item data-v-7f108c9a"><text class="label data-v-7f108c9a">姓名</text><input class="input data-v-7f108c9a" placeholder="请输入访客姓名" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','name','$event',[]],['visitor']]]]]}}" value="{{visitor.name}}" bindinput="__e"/></view><view class="form-item data-v-7f108c9a"><text class="label data-v-7f108c9a">手机号</text><input class="input data-v-7f108c9a" type="number" placeholder="请输入手机号" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','phone','$event',[]],['visitor']]]]]}}" value="{{visitor.phone}}" bindinput="__e"/></view><view class="form-item data-v-7f108c9a"><text class="label data-v-7f108c9a">到访时间</text><picker mode="date" value="{{visitor.expectedVisitTimeStr}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e" class="data-v-7f108c9a"><view class="picker data-v-7f108c9a">{{visitor.expectedVisitTimeStr||'请选择日期'}}</view></picker></view><view class="form-item data-v-7f108c9a"><text class="label data-v-7f108c9a">事由</text><input class="input data-v-7f108c9a" placeholder="如：探访亲友、送快递等" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','reason','$event',[]],['visitor']]]]]}}" value="{{visitor.reason}}" bindinput="__e"/></view><view class="form-item data-v-7f108c9a"><text class="label data-v-7f108c9a">备注</text><textarea class="textarea data-v-7f108c9a" placeholder="选填，如车牌号、特殊需求" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','remark','$event',[]],['visitor']]]]]}}" value="{{visitor.remark}}" bindinput="__e"></textarea></view></view><view class="history-card data-v-7f108c9a"><view class="history-header data-v-7f108c9a"><text class="history-title data-v-7f108c9a">📋 最近邀请</text><text data-event-opts="{{[['tap',[['viewAll',['$event']]]]]}}" class="history-more data-v-7f108c9a" bindtap="__e">查看全部</text></view><block wx:if="{{$root.g0}}"><view class="history-list data-v-7f108c9a"><block wx:for="{{recentInvites}}" wx:for-item="item" wx:for-index="idx" wx:key="idx"><view class="history-item data-v-7f108c9a"><view class="history-info data-v-7f108c9a"><text class="history-name data-v-7f108c9a">{{item.name}}</text><text class="history-date data-v-7f108c9a">{{item.expectedVisitTimeStr}}</text></view><text class="{{['history-status','data-v-7f108c9a',item.status==='已签入'?'signed':'pending']}}">{{item.status}}</text></view></block></view></block><block wx:else><view class="empty-history data-v-7f108c9a"><text class="data-v-7f108c9a">暂无邀请记录</text></view></block></view><view data-event-opts="{{[['tap',[['sendInvite',['$event']]]]]}}" class="submit-btn data-v-7f108c9a" bindtap="__e"><text class="data-v-7f108c9a">发送邀请</text></view><view class="tips data-v-7f108c9a"><text class="tips-text data-v-7f108c9a">* 邀请发出后，访客将收到短信通知，请确保手机号正确</text></view></view>