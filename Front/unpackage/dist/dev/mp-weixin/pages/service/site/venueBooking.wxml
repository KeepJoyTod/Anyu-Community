<view class="booking-page data-v-629d8ca2"><view class="bg-blur data-v-629d8ca2"></view><view class="nav-bar data-v-629d8ca2"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-629d8ca2" bindtap="__e"><text class="back-icon data-v-629d8ca2">←</text></view><text class="nav-title data-v-629d8ca2">场地预约</text><view class="placeholder data-v-629d8ca2"></view></view><view class="section-title data-v-629d8ca2"><text class="data-v-629d8ca2">选择场地</text><text class="section-subtitle data-v-629d8ca2">请选择您要预约的场地</text></view><scroll-view class="venue-scroll data-v-629d8ca2" scroll-x="{{true}}" show-scrollbar="false"><view class="venue-list data-v-629d8ca2"><block wx:for="{{venues}}" wx:for-item="venue" wx:for-index="idx" wx:key="idx"><view data-event-opts="{{[['tap',[['selectVenue',['$0'],[[['venues','',idx]]]]]]]}}" class="{{['venue-card','data-v-629d8ca2',(selectedVenue.id===venue.id)?'active':'']}}" bindtap="__e"><view class="venue-icon data-v-629d8ca2">{{venue.icon}}</view><text class="venue-name data-v-629d8ca2">{{venue.name}}</text><text class="venue-desc data-v-629d8ca2">{{venue.desc}}</text><view class="venue-price data-v-629d8ca2">{{"¥"+venue.price+"/时"}}</view></view></block></view></scroll-view><block wx:if="{{selectedVenue.id}}"><view class="booking-card data-v-629d8ca2"><view class="booking-header data-v-629d8ca2"><text class="booking-title data-v-629d8ca2">预约信息</text></view><view class="form-item data-v-629d8ca2"><text class="label data-v-629d8ca2">预约日期</text><picker mode="date" value="{{bookingDate}}" start="{{minDate}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e" class="data-v-629d8ca2"><view class="picker data-v-629d8ca2">{{bookingDate||'请选择日期'}}</view></picker></view><view class="form-item data-v-629d8ca2"><text class="label data-v-629d8ca2">开始时间</text><picker mode="time" value="{{startTime}}" data-event-opts="{{[['change',[['onStartTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-629d8ca2"><view class="picker data-v-629d8ca2">{{startTime||'请选择时间'}}</view></picker></view><view class="form-item data-v-629d8ca2"><text class="label data-v-629d8ca2">结束时间</text><picker mode="time" value="{{endTime}}" data-event-opts="{{[['change',[['onEndTimeChange',['$event']]]]]}}" bindchange="__e" class="data-v-629d8ca2"><view class="picker data-v-629d8ca2">{{endTime||'请选择时间'}}</view></picker></view><view class="form-item data-v-629d8ca2"><text class="label data-v-629d8ca2">备注</text><textarea class="textarea data-v-629d8ca2" placeholder="选填，如人数、特殊需求" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['','remark','$event',[]]]]]]}}" value="{{remark}}" bindinput="__e"></textarea></view><block wx:if="{{duration}}"><view class="fee-preview data-v-629d8ca2"><text class="data-v-629d8ca2">{{"预计时长："+duration+" 小时"}}</text><text class="total-fee data-v-629d8ca2">{{"总费用：¥"+totalFee}}</text></view></block><view data-event-opts="{{[['tap',[['submitBooking',['$event']]]]]}}" class="{{['submit-btn','data-v-629d8ca2',(isLoading)?'disabled':'']}}" bindtap="__e"><text class="data-v-629d8ca2">{{isLoading?'提交中...':'立即预约'}}</text></view></view></block><block wx:else><view class="empty-tip data-v-629d8ca2"><text class="data-v-629d8ca2">👈 请先选择上方场地</text></view></block><view class="tips data-v-629d8ca2"><text class="tips-text data-v-629d8ca2">* 预约成功后，请按时到场，如需取消请提前2小时</text></view></view>