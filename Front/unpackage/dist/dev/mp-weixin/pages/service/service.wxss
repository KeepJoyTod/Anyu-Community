
.service-page.data-v-4c0f6f1c {
	position: relative;
	min-height: 100vh;
	background: #f6f9fc;
	padding: 0 32rpx 80rpx;
	overflow-x: hidden;
}

/* 动态模糊背景层，增加深度 */
.bg-blur.data-v-4c0f6f1c {
	position: fixed;
	top: -20%;
	right: -20%;
	width: 140%;
	height: 140%;
	background: radial-gradient(circle at 80% 20%, rgba(107, 140, 66, 0.08) 0%, rgba(107, 140, 66, 0.02) 60%, transparent 90%);
	pointer-events: none;
	z-index: 0;
}

/* 头部区域 */
.header.data-v-4c0f6f1c {
	position: relative;
	z-index: 2;
	padding-top: 80rpx;
	padding-bottom: 40rpx;
}
.title.data-v-4c0f6f1c {
	font-size: 64rpx;
	font-weight: 700;
	background: linear-gradient(115deg, #1c3e2b 0%, #2b6e3f 100%);
	background-clip: text;
	-webkit-background-clip: text;
	color: transparent;
	letter-spacing: -1rpx;
}
.subtitle.data-v-4c0f6f1c {
	font-size: 28rpx;
	color: #7e8d9e;
	margin-top: 12rpx;
	font-weight: 450;
	letter-spacing: 0.3rpx;
}

/* 余额卡片 */
.balance-cards.data-v-4c0f6f1c {
	display: flex;
	gap: 24rpx;
	margin-bottom: 48rpx;
	position: relative;
	z-index: 2;
}
.card.data-v-4c0f6f1c {
	flex: 1;
	background: rgba(255, 255, 255, 0.92);
	-webkit-backdrop-filter: blur(12rpx);
	        backdrop-filter: blur(12rpx);
	border-radius: 44rpx;
	padding: 28rpx 24rpx 24rpx;
	box-shadow: 0 20rpx 40rpx -16rpx rgba(0, 0, 0, 0.08), 0 0 0 1rpx rgba(107, 140, 66, 0.08);
	transition: all 0.35s cubic-bezier(0.2, 0.9, 0.4, 1.1);
	position: relative;
	overflow: hidden;
}
.card.data-v-4c0f6f1c:active {
	-webkit-transform: scale(0.97);
	        transform: scale(0.97);
	box-shadow: 0 12rpx 28rpx -12rpx rgba(0, 0, 0, 0.12);
}
.card-glow.data-v-4c0f6f1c {
	position: absolute;
	top: -20%;
	left: -20%;
	width: 140%;
	height: 140%;
	background: radial-gradient(circle, rgba(255,255,240,0.4) 0%, rgba(255,255,255,0) 70%);
	opacity: 0;
	transition: opacity 0.4s;
}
.card:active .card-glow.data-v-4c0f6f1c {
	opacity: 0.6;
}
.water-card.data-v-4c0f6f1c {
	border-left: 6rpx solid #48b87c;
}
.electricity-card.data-v-4c0f6f1c {
	border-left: 6rpx solid #f6a85b;
}
.card-icon.data-v-4c0f6f1c {
	font-size: 52rpx;
	margin-bottom: 20rpx;
	width: 72rpx;
	height: 72rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	background: rgba(72, 184, 124, 0.12);
	border-radius: 36rpx;
}
.electricity-card .card-icon.data-v-4c0f6f1c {
	background: rgba(246, 168, 91, 0.12);
}
.card-content.data-v-4c0f6f1c {
	flex: 1;
}
.card-header.data-v-4c0f6f1c {
	display: flex;
	justify-content: space-between;
	align-items: baseline;
	margin-bottom: 16rpx;
	flex-wrap: wrap;
}
.label.data-v-4c0f6f1c {
	font-size: 28rpx;
	font-weight: 500;
	color: #4a5e71;
}
.status.data-v-4c0f6f1c {
	font-size: 22rpx;
	padding: 4rpx 14rpx;
	border-radius: 40rpx;
	font-weight: 500;
	background: rgba(0,0,0,0.04);
}
.status.normal.data-v-4c0f6f1c {
	color: #2b8c5e;
	background: rgba(43, 140, 94, 0.12);
}
.status.sufficient.data-v-4c0f6f1c {
	color: #e6892e;
	background: rgba(230, 137, 46, 0.12);
}
.value.data-v-4c0f6f1c {
	font-size: 56rpx;
	font-weight: 800;
	color: #1c2e3a;
	letter-spacing: -1rpx;
}
.unit.data-v-4c0f6f1c {
	font-size: 26rpx;
	font-weight: 500;
	color: #8b9bae;
	margin-left: 6rpx;
}
.recharge-badge.data-v-4c0f6f1c {
	align-self: flex-end;
	margin-top: 18rpx;
	background: rgba(107, 140, 66, 0.12);
	padding: 10rpx 20rpx;
	border-radius: 60rpx;
	font-size: 24rpx;
	font-weight: 600;
	color: #6b8c42;
	transition: all 0.2s;
	text-align: center;
	width: -webkit-fit-content;
	width: fit-content;
}
.electricity-card .recharge-badge.data-v-4c0f6f1c {
	background: rgba(246, 168, 91, 0.14);
	color: #e6892e;
}

/* 服务网格 */
.service-grid.data-v-4c0f6f1c {
	display: flex;
	flex-wrap: wrap;
	justify-content: space-between;
	margin-bottom: 48rpx;
	position: relative;
	z-index: 2;
}
.grid-item.data-v-4c0f6f1c {
	width: calc(33.33% - 18rpx);
	background: rgba(255, 255, 255, 0.88);
	-webkit-backdrop-filter: blur(8rpx);
	        backdrop-filter: blur(8rpx);
	border-radius: 32rpx;
	padding: 32rpx 0 28rpx;
	margin-bottom: 24rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
	transition: all 0.25s ease;
	box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.02), 0 0 0 1rpx rgba(107, 140, 66, 0.06);
}
.grid-item.data-v-4c0f6f1c:active {
	-webkit-transform: translateY(-6rpx);
	        transform: translateY(-6rpx);
	background: white;
	box-shadow: 0 20rpx 30rpx -14rpx rgba(107, 140, 66, 0.2), 0 0 0 1rpx rgba(107, 140, 66, 0.2);
}
.icon-bg.data-v-4c0f6f1c {
	width: 100rpx;
	height: 100rpx;
	background: linear-gradient(135deg, #f4f9f0 0%, #eaf2e3 100%);
	border-radius: 52rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-bottom: 20rpx;
	transition: all 0.25s;
	box-shadow: inset 0 1rpx 2rpx rgba(255,255,255,0.8), 0 4rpx 12rpx rgba(0,0,0,0.02);
}
.grid-item:active .icon-bg.data-v-4c0f6f1c {
	background: linear-gradient(135deg, #e2f0d9 0%, #d4e6c8 100%);
	-webkit-transform: scale(0.96);
	        transform: scale(0.96);
}
.icon-text.data-v-4c0f6f1c {
	font-size: 56rpx;
	line-height: 1;
}
.name.data-v-4c0f6f1c {
	font-size: 26rpx;
	font-weight: 500;
	color: #2a4458;
	letter-spacing: 0.3rpx;
}

