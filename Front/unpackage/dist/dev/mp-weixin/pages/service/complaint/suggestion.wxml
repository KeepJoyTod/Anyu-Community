<view class="suggestion-page data-v-2b8f76fb"><view class="bg-blur data-v-2b8f76fb"></view><view class="nav-bar data-v-2b8f76fb"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-2b8f76fb" bindtap="__e"><text class="back-icon data-v-2b8f76fb">←</text></view><text class="nav-title data-v-2b8f76fb">建议反馈</text></view><view class="tab-bar data-v-2b8f76fb"><view data-event-opts="{{[['tap',[['switchTab',['complaint']]]]]}}" class="{{['tab-item','data-v-2b8f76fb',(currentTab==='complaint')?'active':'']}}" bindtap="__e"> 投诉反馈 </view><view data-event-opts="{{[['tap',[['switchTab',['suggestion']]]]]}}" class="{{['tab-item','data-v-2b8f76fb',(currentTab==='suggestion')?'active':'']}}" bindtap="__e"> 建议反馈 </view><view data-event-opts="{{[['tap',[['switchTab',['record']]]]]}}" class="{{['tab-item','data-v-2b8f76fb',(currentTab==='record')?'active':'']}}" bindtap="__e"> 我的记录 </view></view><view class="form-card data-v-2b8f76fb"><view class="form-item data-v-2b8f76fb"><text class="label data-v-2b8f76fb">建议标题</text><input class="input data-v-2b8f76fb" placeholder="请概括您的建议（必填）" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','title','$event',[]],['form']]]]]}}" value="{{form.title}}" bindinput="__e"/></view><view class="form-item data-v-2b8f76fb"><text class="label data-v-2b8f76fb">建议内容</text><textarea class="textarea data-v-2b8f76fb" placeholder="请详细描述您的想法或改进方案（必填）" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','content','$event',[]],['form']]]]]}}" value="{{form.content}}" bindinput="__e"></textarea></view><view class="form-item data-v-2b8f76fb"><text class="label data-v-2b8f76fb">联系方式</text><input class="input data-v-2b8f76fb" placeholder="手机号/邮箱（方便我们与您沟通）" placeholder-class="placeholder" data-event-opts="{{[['input',[['__set_model',['$0','contact','$event',[]],['form']]]]]}}" value="{{form.contact}}" bindinput="__e"/></view><view class="form-item data-v-2b8f76fb"><text class="label data-v-2b8f76fb">上传图片</text><view class="image-list data-v-2b8f76fb"><block wx:for="{{images}}" wx:for-item="img" wx:for-index="idx" wx:key="idx"><view class="image-item data-v-2b8f76fb"><image class="uploaded-img data-v-2b8f76fb" src="{{img}}" mode="aspectFill" data-event-opts="{{[['tap',[['previewImage',[idx]]]]]}}" bindtap="__e"></image><view data-event-opts="{{[['tap',[['deleteImage',[idx]]]]]}}" class="delete-btn data-v-2b8f76fb" bindtap="__e">×</view></view></block><block wx:if="{{$root.g0<4}}"><view data-event-opts="{{[['tap',[['chooseImage',['$event']]]]]}}" class="add-image data-v-2b8f76fb" bindtap="__e"><text class="add-icon data-v-2b8f76fb">+</text><text class="add-text data-v-2b8f76fb">上传图片</text></view></block></view><text class="tip-text data-v-2b8f76fb">最多上传4张图片，支持jpg/png格式</text></view><view data-event-opts="{{[['tap',[['submit',['$event']]]]]}}" class="submit-btn data-v-2b8f76fb" bindtap="__e"><text class="data-v-2b8f76fb">提交建议</text></view></view><view class="tips data-v-2b8f76fb"><text class="tips-text data-v-2b8f76fb">* 您的建议是我们进步的动力，感谢您的参与</text></view></view>