<view class="recharge-page electricity-theme data-v-61d0f890"><view class="bg-blur data-v-61d0f890"></view><view class="nav-bar data-v-61d0f890"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="back-btn data-v-61d0f890" bindtap="__e"><text class="back-icon data-v-61d0f890">←</text></view><text class="nav-title data-v-61d0f890">电费充值</text><view class="placeholder data-v-61d0f890"></view></view><view class="balance-card data-v-61d0f890"><view class="balance-label data-v-61d0f890">当前余额</view><view class="balance-value data-v-61d0f890">{{balance}}<text class="unit data-v-61d0f890"> 元</text></view><view class="balance-tip data-v-61d0f890">{{"可用电量 "+electricityAmount+" 度"}}</view></view><view class="input-section data-v-61d0f890"><view class="section-title data-v-61d0f890">充值金额</view><view class="amount-input-wrapper data-v-61d0f890"><text class="currency data-v-61d0f890">¥</text><input class="amount-input data-v-61d0f890" type="number" placeholder="请输入金额" placeholder-class="input-placeholder" data-event-opts="{{[['input',[['__set_model',['','amount','$event',[]]]]]]}}" value="{{amount}}" bindinput="__e"/></view></view><view class="quick-section data-v-61d0f890"><view class="section-title data-v-61d0f890">快捷充值</view><view class="quick-options data-v-61d0f890"><block wx:for="{{quickAmounts}}" wx:for-item="item" wx:for-index="__i0__" wx:key="*this"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({item})}}" class="{{['quick-item','data-v-61d0f890',(amount==item)?'active':'']}}" bindtap="__e">{{'¥'+item+''}}</view></block></view></view><view class="payment-section data-v-61d0f890"><view class="section-title data-v-61d0f890">支付方式</view><view class="payment-options data-v-61d0f890"><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" class="{{['payment-item','data-v-61d0f890',(payMethod==='wechat')?'active':'']}}" bindtap="__e"><text class="pay-icon data-v-61d0f890">💬</text><text class="pay-name data-v-61d0f890">微信支付</tex