<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mapper.CommunityUserMapper">
    
    <resultMap type="com.ruoyi.domain.CommunityUser" id="CommunityUserResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="phone"    column="phone"    />
        <result property="idCard"    column="id_card"    />
        <result property="gender"    column="gender"    />
        <result property="birthday"    column="birthday"    />
        <result property="liveData"    column="live_data"    />
        <result property="specificAddress"    column="specific_address"    />
        <result property="emergencyContact"    column="emergency_contact"    />
        <result property="emergencyPhone"    column="emergency_phone"    />
        <result property="password"    column="password"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectCommunityUserVo">
        select id, name, phone, id_card, gender, birthday, live_data, specific_address, emergency_contact, emergency_phone, password, create_by, create_time, update_by, update_time, remark from community_user
    </sql>

    <select id="selectCommunityUserByPhone" parameterType="String" resultMap="CommunityUserResult">
        <include refid="selectCommunityUserVo"/>
        where phone = #{phone}
    </select>

    <select id="selectCommunityUserById" parameterType="Long" resultMap="CommunityUserResult">
        <include refid="selectCommunityUserVo"/>
        where id = #{id}
    </select>

    <update id="updateCommunityUser" parameterType="com.ruoyi.domain.CommunityUser">
        update community_user
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthday != null">birthday = #{birthday},</if>
            <if test="liveData != null">live_data = #{liveData},</if>
            <if test="specificAddress != null">specific_address = #{specificAddress},</if>
            <if test="emergencyContact != null">emergency_contact = #{emergencyContact},</if>
            <if test="emergencyPhone != null">emergency_phone = #{emergencyPhone},</if>
            <if test="password != null">password = #{password},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

</mapper>
