<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.notice.mapper.CommunityUserMapper">
    
    <resultMap type="com.ruoyi.community.domain.CommunityUser" id="CommunityUserResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="phone"    column="phone"    />
        <result property="idCard"    column="id_card"    />
        <result property="gender"    column="gender"    />
        <result property="birthday"    column="birthday"    />
        <result property="liveData"    column="live_data"    />
        <result property="specificAddress"    column="specific_address"    />
        <result property="emergencyContact"    column="emergency_contact"    />
        <result property="emergencyPhone"    column="emergency_phone"    />
        <result property="password"    column="password"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

<!--    <sql id="selectCommunityUserVo">-->
<!--        select id, name, phone, id_card, gender, birthday, live_data, specific_address, emergency_contact, emergency_phone, password, create_by, create_time, update_by, update_time, remark from community_user-->
<!--    </sql>-->

    <select id="selectCommunityUserByPhone" parameterType="String" resultMap="CommunityUserResult">
        select id, user_name, phone, room_id, community_id,
               user_type, status, create_time, update_time, remark
        from community_user
        where phone = #{phone}
    </select>

    <select id="selectCommunityUserById" parameterType="Long" resultMap="CommunityUserResult">
        select id, user_name, phone, room_id, community_id,
               user_type, status, create_time, update_time, remark
        from community_user
        where id = #{id}
    </select>
    <select id="selectMyHouse" resultType="java.lang.String">
        select community_user.specific_address from community_user where name= #{username}
    </select>

    <update id="updateCommunityUser" parameterType="com.ruoyi.community.domain.CommunityUser">
        update community_user set
                                  name = #{name},
                                  id_card = #{idCard},
                                  gender = #{gender},
                                  birthday = #{birthday},
                                  live_data = #{liveData},
                                  specific_address = #{specificAddress},
                                  emergency_contact = #{emergencyContact},
                                  emergency_phone = #{emergencyPhone},
                                  password = #{password},
                                  update_by = #{updateBy},
                                  update_time = #{updateTime},
                                  remark = #{remark}
        where id = #{id}
    </update>

</mapper>
