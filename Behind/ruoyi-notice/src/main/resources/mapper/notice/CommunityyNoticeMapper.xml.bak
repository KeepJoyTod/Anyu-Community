<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.notice.mapper.CommunityyNoticeMapper">
    
    <resultMap type="com.ruoyi.notice.domain.CommunityyNotice" id="CommunityNoticeResult">
        <result property="id"    column="id"    />
        <result property="noticeTitle"    column="notice_title"    />
        <result property="noticeContent"    column="notice_content"    />
        <result property="noticeType"    column="notice_type"    />
        <result property="publishUserId"    column="publish_user_id"    />
        <result property="publishUserName"    column="publish_user_name"    />
        <result property="publishTime"    column="publish_time"    />
        <result property="status"    column="status"    />
        <result property="topFlag"    column="top_flag"    />
        <result property="topEndTime"    column="top_end_time"    />
        <result property="readCount"    column="read_count"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectCommunityNoticeVo">
        select id, notice_title, notice_content, notice_type, publish_user_id, publish_user_name, publish_time, status, top_flag, top_end_time, read_count, create_by, create_time, update_by, update_time, remark from community_notice
    </sql>

    <select id="selectCommunityNoticeList" parameterType="com.ruoyi.notice.domain.CommunityyNotice" resultMap="CommunityNoticeResult">
        <include refid="selectCommunityNoticeVo"/>
        <where>  
            <if test="noticeTitle != null  and noticeTitle != ''"> and notice_title = #{noticeTitle}</if>
            <if test="noticeContent != null  and noticeContent != ''"> and notice_content = #{noticeContent}</if>
            <if test="noticeType != null  and noticeType != ''"> and notice_type = #{noticeType}</if>
            <if test="publishUserId != null "> and publish_user_id = #{publishUserId}</if>
            <if test="publishUserName != null  and publishUserName != ''"> and publish_user_name like concat('%', #{publishUserName}, '%')</if>
            <if test="publishTime != null "> and DATE(publish_time) = DATE(#{publishTime})</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="topFlag != null  and topFlag != ''"> and top_flag = #{topFlag}</if>
            <if test="topEndTime != null "> and DATE(top_end_time) = DATE(#{topEndTime})</if>
            <if test="readCount != null "> and read_count = #{readCount}</if>
        </where>
    </select>
    
    <select id="selectCommunityNoticeById" parameterType="Long" resultMap="CommunityNoticeResult">
        <include refid="selectCommunityNoticeVo"/>
        where id = #{id}
    </select>

    <insert id="insertCommunityNotice" parameterType="com.ruoyi.notice.domain.CommunityyNotice" useGeneratedKeys="true" keyProperty="id">
        insert into community_notice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="noticeTitle != null and noticeTitle != ''">notice_title,</if>
            <if test="noticeContent != null and noticeContent != ''">notice_content,</if>
            <if test="noticeType != null and noticeType != ''">notice_type,</if>
            <if test="publishUserId != null">publish_user_id,</if>
            <if test="publishUserName != null and publishUserName != ''">publish_user_name,</if>
            <if test="publishTime != null">publish_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="topFlag != null">top_flag,</if>
            <if test="topEndTime != null">top_end_time,</if>
            <if test="readCount != null">read_count,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="noticeTitle != null and noticeTitle != ''">#{noticeTitle},</if>
            <if test="noticeContent != null and noticeContent != ''">#{noticeContent},</if>
            <if test="noticeType != null and noticeType != ''">#{noticeType},</if>
            <if test="publishUserId != null">#{publishUserId},</if>
            <if test="publishUserName != null and publishUserName != ''">#{publishUserName},</if>
            <if test="publishTime != null">#{publishTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="topFlag != null">#{topFlag},</if>
            <if test="topEndTime != null">#{topEndTime},</if>
            <if test="readCount != null">#{readCount},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateCommunityNotice" parameterType="com.ruoyi.notice.domain.CommunityyNotice">
        update community_notice
        <trim prefix="SET" suffixOverrides=",">
            <if test="noticeTitle != null and noticeTitle != ''">notice_title = #{noticeTitle},</if>
            <if test="noticeContent != null and noticeContent != ''">notice_content = #{noticeContent},</if>
            <if test="noticeType != null and noticeType != ''">notice_type = #{noticeType},</if>
            <if test="publishUserId != null">publish_user_id = #{publishUserId},</if>
            <if test="publishUserName != null and publishUserName != ''">publish_user_name = #{publishUserName},</if>
            <if test="publishTime != null">publish_time = #{publishTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="topFlag != null">top_flag = #{topFlag},</if>
            <if test="topEndTime != null">top_end_time = #{topEndTime},</if>
            <if test="readCount != null">read_count = #{readCount},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCommunityNoticeById" parameterType="Long">
        delete from community_notice where id = #{id}
    </delete>

    <delete id="deleteCommunityNoticeByIds" parameterType="String">
        delete from community_notice where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>