<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.community.mapper.CommunityPointsMapper">

    <resultMap type="com.ruoyi.community.domain.CommunityPoints" id="CommunityPointsResult">
        <id     property="pointsId"      column="points_id" />
        <result property="userId"        column="user_id" />
        <result property="totalPoints"   column="total_points" />
        <result property="availablePoints" column="available_points" />
        <result property="frozenPoints"  column="frozen_points" />
        <result property="medalId"       column="medal_id" />
        <result property="createTime"    column="create_time" />
        <result property="updateTime"    column="last_update_time" />
    </resultMap>

    <select id="selectPointsByUserId" parameterType="Long" resultMap="CommunityPointsResult">
        select * from community_points where user_id = #{userId}
    </select>

    <update id="updateAvailablePoints">
        update community_points
        set available_points = available_points + #{points},
            total_points = total_points + #{points},
            last_update_time = now()
        where user_id = #{userId}
    </update>

    <insert id="insertPoints">
        insert into community_points (user_id, total_points, available_points, frozen_points, create_time, last_update_time)
        values (#{userId}, #{points}, #{points}, 0, now(), now())
    </insert>

</mapper>