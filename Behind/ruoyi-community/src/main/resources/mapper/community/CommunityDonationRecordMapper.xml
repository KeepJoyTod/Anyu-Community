<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.community.mapper.CommunityDonationRecordMapper">

    <resultMap type="com.ruoyi.community.domain.CommunityDonationRecord" id="CommunityDonationRecordResult">
        <id property="id" column="id" />
        <result property="donationId" column="donation_id" />
        <result property="donorName" column="donor_name" />
        <result property="donorPhone" column="donor_phone" />
        <result property="amount" column="amount" />
        <result property="message" column="message" />
        <result property="payType" column="pay_type" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <insert id="insertDonationRecord" parameterType="com.ruoyi.community.domain.CommunityDonationRecord">
        INSERT INTO community_donation_record
        (donation_id, donor_name, donor_phone, amount, message, pay_type, status, create_time)
        VALUES
        (#{donationId}, #{donorName}, #{donorPhone}, #{amount}, #{message}, #{payType}, #{status}, NOW())
    </insert>

    <select id="selectDonationRecordList" resultMap="CommunityDonationRecordResult">
        SELECT * FROM community_donation_record
        ORDER BY create_time DESC
    </select>

    <select id="selectDonationRecordByDonationId" parameterType="Long" resultMap="CommunityDonationRecordResult">
        SELECT * FROM community_donation_record
        WHERE donation_id = #{donationId}
        ORDER BY create_time DESC
    </select>

</mapper>
