<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.community.mapper.CommunityCommentMapper">
    <resultMap type="com.ruoyi.community.domain.CommunityComment" id="CommunityCommentResult">
        <id     property="commentId" column="comment_id" />
        <result property="postId"    column="post_id" />
        <result property="userId"    column="user_id" />
        <result property="userName"  column="user_name" />
        <result property="content"   column="content" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <select id="selectCommentsByPostId" parameterType="Long" resultMap="CommunityCommentResult">
        select * from community_comment where post_id = #{postId} order by create_time desc
    </select>

    <insert id="insertComment" parameterType="com.ruoyi.community.domain.CommunityComment" useGeneratedKeys="true" keyProperty="commentId">
        insert into community_comment (post_id, user_id, user_name, content)
        values (#{postId}, #{userId}, #{userName}, #{content})
    </insert>

    <delete id="deleteCommentById">
        delete from community_comment where comment_id = #{commentId}
    </delete>
</mapper>