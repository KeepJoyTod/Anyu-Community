<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.community.mapper.SysCommunityActivityMapper">

    <!-- 结果映射：数据库字段 → 实体类字段 -->
    <resultMap id="ActivityResultMap" type="com.ruoyi.community.domain.SysCommunityActivity">
        <id column="activity_id" property="activityId"/>
        <result column="activity_title" property="activityTitle"/>
        <result column="activity_type" property="activityType"/>
        <result column="activity_content" property="activityContent"/>
        <result column="activity_time" property="activityTime"/>
        <result column="activity_location" property="activityLocation"/>
        <result column="publisher_id" property="publisherId"/>
        <result column="publisher_name" property="publisherName"/>
        <result column="signup_start_time" property="signupStartTime"/>
        <result column="signup_end_time" property="signupEndTime"/>
        <result column="max_participants" property="maxParticipants"/>
        <result column="current_participants" property="currentParticipants"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="remark" property="remark"/>
    </resultMap>


    <!-- 查询活动详情 -->
    <select id="selectActivityById" parameterType="Long" resultMap="ActivityResultMap">
        select activity_id,
               activity_title,
               activity_type,
               activity_content,
               activity_time,
               activity_location,
               publisher_id,
               publisher_name,
               signup_start_time,
               signup_end_time,
               max_participants,
               current_participants,
               status,
               create_time,
               update_time,
               remark
        from community_activity
        where activity_id = #{activityId}
    </select>


    <!--    取消报名-->
    <update id="cancelRegister">
        UPDATE community_activity
        SET current_participants = current_participants - 1
        WHERE activity_id = #{activityId}
    </update>


    <update id="updateParticipantCount">

        UPDATE community_activity
        SET current_participants = current_participants + 1
        WHERE activity_id = #{activityId}

    </update>

    <!--查询所有活动-->
    <select id="selectAllActivity" resultMap="ActivityResultMap">
        SELECT *
        FROM community_activity
    </select>

</mapper>
