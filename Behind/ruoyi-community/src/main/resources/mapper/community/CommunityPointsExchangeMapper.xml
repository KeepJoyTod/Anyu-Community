<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.community.mapper.CommunityPointsExchangeMapper">

    <insert id="insertPointsExchange" parameterType="com.ruoyi.community.domain.CommunityPointsExchange" useGeneratedKeys="true" keyProperty="id">
        insert into community_points_exchange (
            user_id, user_name, bill_type, bill_id, points_used, amount_offset, exchange_time, remark
        ) values (
            #{userId}, #{userName}, #{billType}, #{billId}, #{pointsUsed}, #{amountOffset}, #{exchangeTime}, #{remark}
        )
    </insert>

    <resultMap id="PointsExchangeResult" type="com.ruoyi.community.domain.CommunityPointsExchange">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="user_name"/>
        <result property="billType" column="bill_type"/>
        <result property="billId" column="bill_id"/>
        <result property="pointsUsed" column="points_used"/>
        <result property="amountOffset" column="amount_offset"/>
        <result property="exchangeTime" column="exchange_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <select id="selectByUserId" parameterType="Long" resultMap="PointsExchangeResult">
        select * from community_points_exchange
        where user_id = #{userId}
        order by exchange_time desc
    </select>

</mapper>